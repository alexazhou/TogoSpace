{
  "development_mode": true,
  "demo_mode": {
    "enabled": true,
    "freeze_data": true,
    "hide_sensitive_info": true
  },
  "llm_providers": [
    {
      "name": "demo",
      "type": "openai",
      "api_key": "demo-api-key",
      "enable": true,
      "urls": {
        "openai": "http://127.0.0.1:19876/v1/chat/completions"
      },
      "models": [
        {
          "name": "demo-model",
          "protocol": "openai"
        }
      ],
      "extra_headers": {
        "X-Test": "demo"
      }
    }
  ],
  "default_models": {
    "primary": "demo-model@demo",
    "lite": "demo-model@demo",
    "vision": "",
    "advanced": ""
  },
  "version": "v2"
}