{
  "_comment": "TeamAgent 配置文件，请根据实际 LLM 服务修改",

  "bind_host": "0.0.0.0",
  "bind_port": 8080,

  "demo_mode": {
    "enabled": false,
    "freeze_data": true,
    "hide_sensitive_info": true
  },

  "default_llm_server": "qwen",

  "llm_services": [
    {
      "name": "qwen",
      "enable": false,
      "base_url": "https://dashscope.aliyuncs.com/compatible-mode/v1",
      "api_key": "YOUR_API_KEY_HERE",
      "type": "openai-compatible",
      "model": "qwen-plus"
    }
  ]
}
